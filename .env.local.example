# Resend — transactional email for contact form
# Get a key at https://resend.com/api-keys
RESEND_API_KEY=

# Address contact form submissions get delivered to
CONTACT_TO_EMAIL=russell.sailors@gmail.com

# Verified sender on your Resend domain (e.g. hello@mako.studio)
# Until the domain is verified on Resend, use onboarding@resend.dev
CONTACT_FROM_EMAIL=onboarding@resend.dev
